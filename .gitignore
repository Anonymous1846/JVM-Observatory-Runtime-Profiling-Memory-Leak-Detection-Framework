# ═══════════════════════════════════════════════════════════════
# Java / Maven
# ═══════════════════════════════════════════════════════════════
*.class
*.jar
*.war
*.ear
*.nar
target/
!.mvn/wrapper/maven-wrapper.jar

# ═══════════════════════════════════════════════════════════════
# C++ / CMake (native-agent)
# ═══════════════════════════════════════════════════════════════
native-agent/build/
*.dll
*.so
*.dylib
*.obj
*.o
*.lib
*.exp
*.pdb
*.ilk
CMakeUserPresets.json

# ═══════════════════════════════════════════════════════════════
# Python (analysis-service)
# ═══════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*.egg-info/
dist/
venv/
.venv/
.pytest_cache/

# ═══════════════════════════════════════════════════════════════
# Node / React (visualization)
# ═══════════════════════════════════════════════════════════════
node_modules/
visualization/dist/

# ═══════════════════════════════════════════════════════════════
# IDE
# ═══════════════════════════════════════════════════════════════
.idea/
*.iml
.vscode/
*.suo
*.user
*.sln.docuser
.vs/
*.swp
*~

# ═══════════════════════════════════════════════════════════════
# OS
# ═══════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
Desktop.ini

# ═══════════════════════════════════════════════════════════════
# Logs and crash dumps
# ═══════════════════════════════════════════════════════════════
*.log
hs_err_pid*
replay_pid*

# ═══════════════════════════════════════════════════════════════
# Secrets (never commit these)
# ═══════════════════════════════════════════════════════════════
.env
*.pem
*.key
credentials.json
